{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "./src",
    "paths": {
      "@core/*": ["core/*"],
      "@shared/*": ["shared/*"],
      "@apis": ["apis"],
      "@apis/*": ["apis/*"],
      "@infra/*": ["infra/*"],
      "@infra": ["infra"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/apis/_template/**/*"]
}
